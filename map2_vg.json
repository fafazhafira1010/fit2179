{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
"height": 500,
"padding": {"top": 10, "right": 20, "bottom": 10, "left": 10},
  "title": "Taylor Swift World Tours — Shows & Revenue by Location",
  "projection": {"type": "equalEarth"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/3_choropleth_map/js/ne_110m_admin_0_countries.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "mark": {"type": "geoshape", "fill": "#ddd", "stroke": "#fff", "strokeWidth": 0.5}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/3_choropleth_map/js/ne_110m_admin_0_countries.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "transform": [
        {
          "lookup": "properties.NAME",
          "from": {
            "data": {
              "url": "data/country_shows.csv",
              "format": {"type": "csv"}
            },
            "key": "country_mapped",
            "fields": ["show_count"]
          }
        },
        {"filter": "datum.show_count != null"}
      ],
      "mark": {"type": "geoshape", "stroke": "#fff", "strokeWidth": 0.5},
      "encoding": {
        "color": {
          "field": "show_count",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [1, 5, 15, 50],
            "range": ["#fde0dd", "#fbb4b9", "#f768a1", "#c51b8a", "#7a0177"]
          },
          "legend": {
            "title": "Number of Shows",
            "orient": "right",
            "values": [1, 5, 15, 50],
            "labelExpr": "datum.value == 1 ? '1–4' : datum.value == 5 ? '5–14' : datum.value == 15 ? '15–49' : '50+'"
          }
        },
        "tooltip": [
          {"field": "properties.NAME", "type": "nominal", "title": "Country"},
          {"field": "show_count", "type": "quantitative", "title": "Shows"}
        ]
      }
    },
    {
      "data": {
        "url": "data/Taylor_Train_upd.csv",
        "format": {
          "type": "csv",
          "parse": {"lat": "number", "lng": "number"}
        }
      },
      "transform": [
        {
          "calculate": "toNumber(replace(replace(replace(datum.Revenue, '$', ''), ',', ''), /[^0-9]/g, ''))",
          "as": "revenue_clean"
        },
        {"filter": "datum.revenue_clean > 0"},
        {
          "aggregate": [
            {"op": "sum",   "field": "revenue_clean", "as": "total_revenue"},
            {"op": "count", "as": "show_count"},
            {"op": "min",   "field": "lat", "as": "lat"},
            {"op": "min",   "field": "lng", "as": "lng"}
          ],
          "groupby": ["City", "Country"]
        }
      ],
      "mark": {"type": "circle", "opacity": 0.85, "stroke": "#fff", "strokeWidth": 0.5},
      "encoding": {
        "longitude": {"field": "lng", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "total_revenue",
          "type": "quantitative",
          "scale": {"range": [20, 800]},
          "legend": {
            "title": "Total Revenue (USD)",
            "orient": "right",
            "format": "$,.0f",
            "values": [0, 20000000, 60000000, 120000000],
            "labelExpr": "'$' + format(datum.value / 1000000, '.0f') + 'M'"
          }
        },
        "color": {"value": "#E6A817"},
        "tooltip": [
          {"field": "City",          "type": "nominal",      "title": "City"},
          {"field": "Country",       "type": "nominal",      "title": "Country"},
          {"field": "show_count",    "type": "quantitative", "title": "Shows"},
          {"field": "total_revenue", "type": "quantitative", "title": "Revenue (USD)", "format": "$,.0f"}
        ]
      }
    }
  ],
  "config": {"view": {"stroke": null}}
}